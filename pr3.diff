[32m+import os[m
[32m+import requests[m
[32m+import time[m
[32m+import json[m
[32m+[m
[32m+TOKEN = os.getenv('TELEGRAM_BOT_TOKEN')[m
[32m+# Usamos la URL local para reenviar los mensajes al webhook de Flask[m
[32m+# En Render, Gunicorn usa el puerto definido en $PORT. Por defecto 5000 si no existe.[m
[32m+PORT = os.getenv('PORT', '5000')[m
[32m+WEBHOOK_LOCAL_URL = f"http://127.0.0.1:{PORT}/api/telegram_webhook"[m
[32m+[m
[32m+def run_polling():[m
[32m+    if not TOKEN:[m
[32m+        print("TELEGRAM_BOT_TOKEN no configurado.")[m
[32m+        return[m
[32m+[m
[32m+    print("Iniciando bot en modo polling (segundo plano)...")[m
[32m+    offset = 0[m
[32m+    [m
[32m+    # Eliminar webhook previo para permitir polling[m
[32m+    requests.get(f"https://api.telegram.org/bot{TOKEN}/deleteWebhook")[m
[32m+[m
[32m+    while True:[m
[32m+        try:[m
[32m+            url = f"https://api.telegram.org/bot{TOKEN}/getUpdates?offset={offset}&timeout=30"[m
[32m+            resp = requests.get(url).json()[m
[32m+            [m
[32m+            if resp.get('ok'):[m
[32m+                for update in resp.get('result', []):[m
[32m+                    offset = update['update_id'] + 1[m
[32m+                    # Reenviar a la app Flask localmente[m
[32m+                    try:[m
[32m+                        requests.post(WEBHOOK_LOCAL_URL, json=update, timeout=5)[m
[32m+                    except Exception as e:[m
[32m+                        print(f"Error al reenviar al webhook local: {e}")[m
[32m+            [m
[32m+        except Exception as e:[m
[32m+            print(f"Error en polling: {e}")[m
[32m+            time.sleep(5)[m
[32m+[m
[32m+if __name__ == "__main__":[m
[32m+    run_polling()[m
