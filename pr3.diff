[32m+def normalize_language(lang_code: str | None) -> str:[m
[32m+    if not lang_code:[m
[32m+        return 'es'[m
[32m+    code = str(lang_code).strip().lower().replace('_', '-')[m
[32m+    if code.startswith(('en', 'en-us', 'en-gb')):[m
[32m+        return 'en'[m
[32m+    if code.startswith(('pt', 'pt-br', 'pt-pt')):[m
[32m+        return 'pt'[m
[32m+    if code.startswith(('fr', 'fr-fr', 'fr-ca')):[m
[32m+        return 'fr'[m
[32m+    if code.startswith(('de', 'de-de')):[m
[32m+        return 'de'[m
[32m+    if code.startswith(('it', 'it-it')):[m
[32m+        return 'it'[m
[32m+    if code.startswith(('ja', 'ja-jp')):[m
[32m+        return 'ja'[m
[32m+    if code.startswith(('zh', 'zh-cn', 'zh-hk', 'zh-tw')):[m
[32m+        return 'zh'[m
[32m+    if code.startswith(('es', 'es-es', 'es-mx')):[m
[32m+        return 'es'[m
[32m+    return 'es'[m
[32m+[m
[32m+[m
[32m+def resolve_language(request_obj) -> str:[m
[32m+    requested = ([m
[32m+        request_obj.args.get('lang')[m
[32m+        or session.get('lang')[m
[32m+        or request_obj.cookies.get('lang')[m
[32m+        or request_obj.headers.get('X-Language')[m
[32m+        or request_obj.accept_languages.best_match(list(SUPPORTED_LANGUAGES.keys()))[m
[32m+        or 'es'[m
[32m+    )[m
[32m+    return normalize_language(requested)[m
[32m+[m
[32m+[m
[32m+@app.before_request[m
[32m+def apply_language():[m
[32m+    lang_code = resolve_language(request)[m
[32m+    session['lang'] = lang_code[m
[32m+    g.lang_code = lang_code[m
[32m+    g.lang_name = SUPPORTED_LANGUAGES[lang_code]['name'][m
[32m+    g.translations = TRANSLATIONS[lang_code][m
[32m+    g.available_languages = SUPPORTED_LANGUAGES[m
[32m+[m
[32m+[m
[32m+@app.after_request[m
[32m+def persist_language(response):[m
[32m+    if hasattr(g, 'lang_code'):[m
[32m+        response.set_cookie('lang', g.lang_code, max_age=60 * 60 * 24 * 365, path='/', samesite='Lax')[m
[32m+    return response[m
[32m+[m
[32m+[m
[32m+@app.context_processor[m
[32m+def inject_language_context():[m
[32m+    return {[m
[32m+        'lang_code': getattr(g, 'lang_code', 'es'),[m
[32m+        'lang_name': getattr(g, 'lang_name', 'Español'),[m
[32m+        'translations': getattr(g, 'translations', TRANSLATIONS['es']),[m
[32m+        'available_languages': getattr(g, 'available_languages', SUPPORTED_LANGUAGES),[m
[32m+    }[m
