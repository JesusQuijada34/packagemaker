[32m+#!/bin/bash[m
[32m+[m
[32m+# Función para limpiar procesos al salir[m
[32m+cleanup() {[m
[32m+    echo "Deteniendo procesos..."[m
[32m+    kill $(jobs -p)[m
[32m+    exit[m
[32m+}[m
[32m+[m
[32m+trap cleanup SIGINT SIGTERM[m
[32m+[m
[32m+echo "--- Iniciando Entorno Packagemaker ---"[m
[32m+[m
[32m+# 1. Configurar Webhook primero (si aplica)[m
[32m+# Esto es rápido y no bloqueante, asegura que Telegram sepa a dónde enviar mensajes[m
[32m+if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$WEBHOOK_URL" ]; then[m
[32m+    echo "[Telegram] Configurando Webhook..."[m
[32m+    python3 setup_webhook.py[m
[32m+fi[m
[32m+[m
[32m+# El bot ahora se gestiona principalmente vía Webhook en app.py.[m
[32m+# bot_polling.py queda como respaldo manual si se desea ejecutar localmente.[m
[32m+[m
[32m+# 3. Iniciar el servidor Flask con Gunicorn[m
[32m+# IMPORTANTE: Gunicorn debe ser el proceso principal que mantenga vivo el contenedor/instancia en Render.[m
[32m+# Lo ejecutamos en PRIMER PLANO al final para que Render monitoree este proceso.[m
[32m+echo "[Web] Iniciando servidor Flask con Gunicorn en puerto ${PORT:-5000}..."[m
[32m+exec gunicorn --bind 0.0.0.0:${PORT:-5000} --workers 2 --threads 4 --timeout 120 app:app[m
