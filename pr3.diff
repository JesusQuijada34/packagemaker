@@ -0,0 +1,34 @@
[32m+import os[m
[32m+import requests[m
[32m+import sys[m
[32m+[m
[32m+def setup_webhook():[m
[32m+    token = os.getenv('TELEGRAM_BOT_TOKEN')[m
[32m+    # En Render, la URL suele ser la URL de la app[m
[32m+    webhook_url = os.getenv('WEBHOOK_URL') [m
[32m+    [m
[32m+    if not token:[m
[32m+        print("Error: TELEGRAM_BOT_TOKEN no configurado.")[m
[32m+        return[m
[32m+    [m
[32m+    if not webhook_url:[m
[32m+        print("Error: WEBHOOK_URL no configurado (debe ser la URL de tu app en Render + /api/telegram_webhook).")[m
[32m+        return[m
[32m+[m
[32m+    full_url = f"{webhook_url.rstrip('/')}/api/telegram_webhook"[m
[32m+    api_url = f"https://api.telegram.org/bot{token}/setWebhook"[m
[32m+    [m
[32m+    print(f"Configurando webhook en: {full_url}")[m
[32m+    [m
[32m+    try:[m
[32m+        response = requests.post(api_url, json={'url': full_url})[m
[32m+        result = response.json()[m
[32m+        if result.get('ok'):[m
[32m+            print("✅ Webhook configurado correctamente.")[m
[32m+        else:[m
[32m+            print(f"❌ Error al configurar webhook: {result.get('description')}")[m
[32m+    except Exception as e:[m
[32m+        print(f"❌ Error de conexión: {e}")[m
[32m+[m
[32m+if __name__ == "__main__":[m
[32m+    setup_webhook()[m
