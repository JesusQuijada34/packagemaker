[32m+@app.before_request[m
[32m+def track_visit():[m
[32m+    if not request.path.startswith('/static') and not request.path.startswith('/admin') and not request.path.startswith('/api/track'):[m
[32m+        if 'session_id' not in session: session['session_id'] = str(uuid.uuid4())[m
[32m+        try:[m
[32m+            ua = request.headers.get('User-Agent', '').lower()[m
[32m+            platform = 'Desktop'[m
[32m+            if 'android' in ua: platform = 'Android'[m
[32m+            elif 'windows' in ua: platform = 'Windows'[m
[32m+            conn = sqlite3.connect(DB_PATH)[m
[32m+            c = conn.cursor()[m
[32m+            c.execute("INSERT INTO visits (session_id, timestamp, path, platform, ip) VALUES (?, ?, ?, ?, ?)",[m
[32m+                      (session['session_id'], datetime.now(), request.path, platform, request.remote_addr))[m
[32m+            conn.commit()[m
[32m+            conn.close()[m
[32m+        except Exception as e: print(f"Error tracking: {e}")[m
[32m+[m
[32m+@app.route('/api/track/update', methods=['POST'])[m
[32m+def update_track():[m
[32m+    data = request.json[m
[32m+    session_id = session.get('session_id')[m
[32m+    if session_id and data:[m
[32m+        try:[m
[32m+            conn = sqlite3.connect(DB_PATH)[m
[32m+            c = conn.cursor()[m
[32m+            c.execute("UPDATE visits SET duration = ?, bounced = ? WHERE session_id = ? ORDER BY id DESC LIMIT 1",[m
[32m+                      (data.get('duration', 0), 0 if data.get('duration', 0) > 5 else 1, session_id))[m
[32m+            conn.commit()[m
[32m+            conn.close()[m
[32m+        except: pass[m
[32m+    return jsonify({"status": "ok"})[m
