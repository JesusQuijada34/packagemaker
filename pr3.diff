[32m+def mark_and_notify(ticket, note):[m
[32m+        """Mark a report resolved and attempt notifications; logs attempts."""[m
[32m+        conn = sqlite3.connect(DB_PATH)[m
[32m+        c = conn.cursor()[m
[32m+        c.execute('SELECT reporter_chat_id, reporter_ip, reporter_username FROM reports WHERE ticket = ?', (ticket,))[m
[32m+        row = c.fetchone()[m
[32m+        if not row:[m
[32m+            conn.close()[m
[32m+            return {'ok': False, 'reason': 'not found'}[m
[32m+        reporter_chat_id, reporter_ip, reporter_username = row[m
[32m+        now = datetime.now()[m
[32m+        c.execute('UPDATE reports SET resolved = 1, resolution_note = ?, resolved_at = ? WHERE ticket = ?', (note, now, ticket))[m
[32m+        conn.commit()[m
[32m+        conn.close()[m
[32m+[m
[32m+        notified = False[m
[32m+        notify_info = ''[m
[32m+        if reporter_chat_id:[m
[32m+            res = send_telegram_message(reporter_chat_id, f"Tu reporte {ticket} ha sido resuelto:\n\n{note}")[m
[32m+            success = bool(res)[m
[32m+            notify_info = f'tg:{res}'[m
[32m+            log_notification(ticket, 'telegram', success, notify_info)[m
[32m+            notified = success[m
[32m+        else:[m
[32m+            payload = {'ticket': ticket, 'status': 'resolved', 'note': note}[m
[32m+            ok, info = try_notify_via_ip(reporter_ip, payload)[m
[32m+            notify_info = info[m
[32m+            log_notification(ticket, 'ip', ok, info)[m
[32m+            notified = ok[m
[32m+[m
[32m+        # Inform owner[m
[32m+        owner_msg = f"Reporte {ticket} marcado como resuelto. Notificado: {notified}. Info: {notify_info}"[m
[32m+        if TELEGRAM_OWNER_ID:[m
[32m+            send_telegram_message(TELEGRAM_OWNER_ID, owner_msg)[m
[32m+[m
[32m+        return {'ok': True, 'notified': notified, 'info': notify_info}[m
