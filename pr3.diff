[32m+def get_latest_release_version():[m
[32m+    try:[m
[32m+        response = requests.get(f"https://api.github.com/repos/{GITHUB_REPO}/releases/latest", timeout=8)[m
[32m+        if response.status_code == 200:[m
[32m+            return response.json().get("tag_name") or get_xml_metadata().get("version", "v3.2.7")[m
[32m+    except Exception as e:[m
[32m+        print(f"Error fetching latest release version: {e}")[m
[32m+    return get_xml_metadata().get("version", "v3.2.7")[m
