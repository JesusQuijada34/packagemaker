[32m+const CACHE_NAME = 'pm-v2';[m
[32m+const assets = [[m
[32m+  '/pwaMode?id=mobile',[m
[32m+  '/static/manifest.json',[m
[32m+  'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css'[m
[32m+];[m
[32m+[m
[32m+self.addEventListener('install', event => {[m
[32m+  event.waitUntil(caches.open(CACHE_NAME).then(cache => cache.addAll(assets)));[m
[32m+});[m
[32m+[m
[32m+self.addEventListener('fetch', event => {[m
[32m+  event.respondWith([m
[32m+    caches.match(event.request).then(response => response || fetch(event.request))[m
[32m+  );[m
[32m+});[m
