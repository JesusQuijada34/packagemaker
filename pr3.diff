[32m+def get_download_for_platform(user_agent):[m
[32m+    """Get download info based on platform detection, checking the latest release assets."""[m
[32m+    ua = user_agent.lower()[m
[32m+    all_downloads = get_release_info()[m
[32m+[m
[32m+    if "android" in ua or "mobile" in ua:[m
[32m+        detected_platform = "android"[m
[32m+        preferred_keys = [][m
[32m+    elif "win" in ua or "windows" in ua:[m
[32m+        detected_platform = "windows"[m
[32m+        preferred_keys = ["windows"][m
[32m+    elif "linux" in ua or "ubuntu" in ua or "debian" in ua:[m
[32m+        detected_platform = "linux"[m
[32m+        preferred_keys = ["linux"][m
[32m+    else:[m
[32m+        detected_platform = "desktop"[m
[32m+        preferred_keys = ["windows", "linux"][m
[32m+[m
[32m+    direct_download = None[m
[32m+    for preferred_key in preferred_keys:[m
[32m+        for dl in all_downloads:[m
[32m+            if dl["platform_key"] == preferred_key:[m
[32m+                if check_iflapp_exists(dl["url"]):[m
[32m+                    direct_download = dl[m
[32m+                    break[m
[32m+        if direct_download:[m
[32m+            break[m
[32m+[m
[32m+    download_status = "available"[m
[32m+    if direct_download is None and all_downloads:[m
[32m+        fallback_download = next((dl for dl in all_downloads if check_iflapp_exists(dl["url"])), None)[m
[32m+        if fallback_download:[m
[32m+            direct_download = fallback_download[m
[32m+        else:[m
[32m+            download_status = "unavailable"[m
[32m+[m
[32m+    alternatives = [][m
[32m+    for dl in all_downloads[:6]:[m
[32m+        if dl != direct_download:[m
[32m+            alternatives.append(dl)[m
[32m+[m
[32m+    return {[m
[32m+        "detected_platform": detected_platform,[m
[32m+        "direct_download": direct_download,[m
[32m+        "download_status": download_status,[m
[32m+        "alternatives": alternatives,[m
[32m+        "all_downloads": all_downloads[m
[32m+    }[m
