[32m+def try_notify_via_ip(ip, payload):[m
[32m+        """Attempt simple HTTP callbacks to the reporter IP to notify of resolution."""[m
[32m+        if not ip:[m
[32m+            return False, 'no ip'[m
[32m+        urls = [[m
[32m+            f'http://{ip}/pm/notify',[m
[32m+            f'http://{ip}:9000/pm/notify',[m
[32m+            f'http://{ip}/notify',[m
[32m+            f'http://{ip}:9000/notify'[m
[32m+        ][m
[32m+        headers = {'Content-Type': 'application/json'}[m
[32m+        for u in urls:[m
[32m+            try:[m
[32m+                resp = requests.post(u, json=payload, headers=headers, timeout=3)[m
[32m+                if resp.status_code < 400:[m
[32m+                    return True, f'ok {u} {resp.status_code}'[m
[32m+            except Exception as e:[m
[32m+                # continue trying other endpoints[m
[32m+                last_err = str(e)[m
[32m+        return False, last_err if 'last_err' in locals() else 'failed'[m
